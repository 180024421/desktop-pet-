{
  "name": "desktop-pet",
  "version": "1.4.0",
  "description": "像素桌面宠物 · Sprite Sheet · Shimeji · Bongo 打字联动",
  "main": "dist/main/index.js",
  "author": "180024421",
  "license": "MIT",
  "scripts": {
    "build": "node scripts/build.js",
    "dev": "node scripts/start-electron.js",
    "start": "node scripts/start-electron.js",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.desktop.pet",
    "productName": "Desktop Pet",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "package.json",
      "node_modules/sharp/**/*",
      "node_modules/adm-zip/**/*",
      "node_modules/gifenc/**/*",
      "node_modules/electron-updater/**/*"
    ],
    "extraResources": [
      {
        "from": "bundled/default",
        "to": "bundled/default",
        "filter": ["**/*"]
      },
      {
        "from": "bundled/sprite-cat",
        "to": "bundled/sprite-cat",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "electron-updater": "^6.3.9",
    "gifenc": "^1.0.3",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^22.10.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2"
  }
}
